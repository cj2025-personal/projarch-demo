MONGODB_URI=mongodb+srv://user:password@cluster.example.mongodb.net/?appName=example
MONGODB_DB=ngo_profiles
GCP_PROJECT_ID=your-gcp-project-id
GCP_LOCATION=us-central1
BUCKET_NAME=demo-site-flyer
FLYER_PUBLISH_USERNAME=admin
FLYER_PUBLISH_PASSWORD=change-me
FLYER_PRINT_ORIGIN=https://your-frontend.vercel.app

# Local dev: path to service-account JSON (relative to demo-be/)
GOOGLE_APPLICATION_CREDENTIALS=config/key.json

# Render/production: paste the full service-account JSON (do not set GOOGLE_APPLICATION_CREDENTIALS)
# GCP_SERVICE_ACCOUNT_JSON={"type":"service_account",...}
